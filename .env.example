# Supabase — Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-publishable-or-anon-key

# 선택: 커스텀 도메인 고정 시 (비우면 Vercel의 VERCEL_URL로 자동 설정됨)
# NEXT_PUBLIC_SITE_URL=https://testprj-web.vercel.app

# Supabase → Authentication → URL Configuration
#   Site URL: https://testprj-web.vercel.app (또는 본인 도메인)
#   Redirect URLs에 아래 모두 추가:
#     https://testprj-web.vercel.app/auth/callback
#     http://localhost:3000/auth/callback

# Vercel → Environment Variables: SUPABASE_URL, SUPABASE_ANON_KEY (Production + Preview)
