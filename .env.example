# Supabase — Project Settings → API
# SUPABASE_* 또는 아래 NEXT_PUBLIC_* 중 편한 이름만 쓰면 됩니다.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-publishable-or-anon-key

# 대시보드에서 복사한 이름이 이렇게만 나올 수 있음 (next.config에서 ANON_KEY로 연결됨)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Google 로그인: Supabase → Authentication → URL Configuration
#   Redirect URLs에 http://localhost:3000/auth/callback (배포 도메인도 추가)
#   Providers → Google: Client ID/Secret (Google Cloud OAuth 클라이언트)
